# ndx_options/.env — Copy this to .env and fill in your credentials.
# NEVER commit .env to git.

# IBKR TWS / IB Gateway
IBKR_HOST=127.0.0.1
IBKR_PAPER_PORT=7497
IBKR_LIVE_PORT=7496
IBKR_CLIENT_ID=10
IBKR_ACCOUNT=         # leave blank to use default managed account (e.g. U23445314)

# TradingView MCP server path (used by core/market_data.py)
# TV_MCP_PATH=../mcp/src/server.js

# Optional: notification webhook (Slack / Discord)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
